{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile photo URL" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "rooms": {
      "title": "Room Metadata",
      "description": "Stores persistent room information.",
      "type": "object",
      "properties": {
        "roomId": { "type": "string", "description": "Unique room ID" },
        "createdBy": { "type": "string", "description": "UID of the room creator" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Room creation timestamp" },
        "title": { "type": "string", "description": "Optional room title" }
      },
      "required": ["roomId", "createdBy", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "users",
      "description": "User profile document"
    },
    "/rooms/{roomId}": {
      "schema": "rooms",
      "description": "Room metadata document"
    }
  }
}
